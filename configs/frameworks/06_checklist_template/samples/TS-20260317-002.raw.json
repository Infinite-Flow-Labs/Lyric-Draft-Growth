                "offset": 0
              }
            ],
            "inlineStyleRanges": [],
            "key": "7bb8n",
            "text": " ",
            "type": "atomic"
          },
          {
            "data": {},
            "entityRanges": [],
            "inlineStyleRanges": [],
            "key": "b2j1g",
            "text": "获取地址二，如下操作：",
            "type": "unstyled"
          },
          {
            "data": {},
            "entityRanges": [
              {
                "key": 5,
                "length": 1,
                "offset": 0
              }
            ],
            "inlineStyleRanges": [],
            "key": "4hcd0",
