{
  "contract_version": "article_publish_contract_v2",
  "scope": "article_mode",
  "allowed_block_types": [
    "hero_heading",
    "section_heading",
    "paragraph",
    "bullet_list",
    "quote",
    "link_cta",
    "closing_slogan"
  ],
  "required_minimum": {
    "hero_heading": 1,
    "section_heading": 2,
    "quote": 1,
    "bullet_list": 1
  },
  "hard_checks": [
    "first_block_must_be_hero_heading",
    "bullet_list_requires_items",
    "quote_requires_text",
    "link_cta_requires_text_or_url",
    "inline_insertion_anchor_in_range",
    "inline_insertion_requires_text_before_after"
  ],
  "inline_anchor_min_chars": {
    "before": 100,
    "after": 100
  },
  "notes": "Assembler and publisher both enforce this contract before publish."
}
