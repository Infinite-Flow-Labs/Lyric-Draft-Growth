{
  "schema_version": "0.1.0",
  "policy_id": "topic_engine_policy_v1",
  "description": "Single-lane pilot scoring policy for topic selection.",
  "source_roles": {
    "post_x": "heat_signal",
    "official_x": "fact_base",
    "article_x": "fact_base",
    "github_trending": "fact_base",
    "podcast": "context_support"
  },
  "global_gate": {
    "max_age_hours": 168,
    "require_canonical_url": true,
    "min_text_words": 25,
    "drop_if_exact_duplicate": true
  },
  "family_overrides": {
    "official_x": {
      "max_age_hours": 168,
      "min_text_words": 18
    },
    "article_x": {
      "max_age_hours": 240,
      "min_text_words": 25
    },
    "post_x": {
      "max_age_hours": 96,
      "min_text_words": 8
    }
  },
  "topic_priority_weights": {
    "volume_score": 0.35,
    "velocity_score": 0.25,
    "cross_source_resonance_score": 0.25,
    "novelty_score": 0.15
  },
  "topic_thresholds": {
    "min_topic_priority_for_write": 38,
    "max_signals_per_topic": 12,
    "min_source_families_for_priority": 1,
    "cluster_similarity_threshold": 2
  },
  "lane_blend": {
    "lane_fit_weight": 0.7,
    "topic_priority_weight": 0.3
  }
}
