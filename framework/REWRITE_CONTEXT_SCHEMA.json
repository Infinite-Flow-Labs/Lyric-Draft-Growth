{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growth-engine.local/rewrite_context.schema.json",
  "title": "RewriteContext",
  "description": "Deterministically assembled writing payload. This object is not an LLM summary. It is a selected projection of FRAMEWORK_SPEC.json after framework routing is finalized.",
  "type": "object",
  "additionalProperties": false,
    "required": [
      "schema_version",
      "assembly_mode",
      "assembled_at",
      "source_ref",
    "framework_match_ref",
    "framework_spec_ref",
    "selected_framework",
    "assembly_manifest",
    "structure_packet",
      "style_packet",
      "sample_packet",
      "execution_packet",
      "writer_guardrails",
      "capability_packets"
    ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "submode_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submode_id",
        "label",
        "summary",
        "use_when",
        "avoid_when",
        "source_fit",
        "source_unfit",
        "hidden_flow",
        "hook_patterns",
        "evidence_mix",
        "reasoning_moves",
        "rewrite_formula",
        "surface_forms",
        "anti_patterns",
        "style_profile_id",
        "sample_ids"
      ],
      "properties": {
        "submode_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "use_when": {
          "$ref": "#/$defs/string_list"
        },
        "avoid_when": {
          "$ref": "#/$defs/string_list"
        },
        "source_fit": {
          "$ref": "#/$defs/string_list"
        },
        "source_unfit": {
          "$ref": "#/$defs/string_list"
        },
        "hidden_flow": {
          "$ref": "#/$defs/string_list"
        },
        "hook_patterns": {
          "$ref": "#/$defs/string_list"
        },
        "evidence_mix": {
          "$ref": "#/$defs/string_list"
        },
        "reasoning_moves": {
          "$ref": "#/$defs/string_list"
        },
        "rewrite_formula": {
          "$ref": "#/$defs/non_empty_string"
        },
        "surface_forms": {
          "$ref": "#/$defs/string_list"
        },
        "anti_patterns": {
          "$ref": "#/$defs/string_list"
        },
        "style_profile_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sample_ids": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "style_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style_profile_id",
        "submode_id",
        "tone_core",
        "opening_moves",
        "sentence_rhythm",
        "surface_forms",
        "language_moves",
        "keep",
        "avoid",
        "ai_smells",
        "one_sentence_portrait"
      ],
      "properties": {
        "style_profile_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "submode_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "tone_core": {
          "$ref": "#/$defs/non_empty_string"
        },
        "opening_moves": {
          "$ref": "#/$defs/string_list"
        },
        "sentence_rhythm": {
          "$ref": "#/$defs/string_list"
        },
        "surface_forms": {
          "$ref": "#/$defs/string_list"
        },
        "language_moves": {
          "$ref": "#/$defs/string_list"
        },
        "keep": {
          "$ref": "#/$defs/string_list"
        },
        "avoid": {
          "$ref": "#/$defs/string_list"
        },
        "ai_smells": {
          "$ref": "#/$defs/string_list"
        },
        "one_sentence_portrait": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "sample_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_id",
        "title",
        "url",
        "author",
        "submode_id",
        "why_it_matters",
        "hook_move",
        "proof_mode",
        "reusable_parts",
        "non_reusable_parts",
        "style_cue"
      ],
      "properties": {
        "sample_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "author": {
          "$ref": "#/$defs/non_empty_string"
        },
        "submode_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "why_it_matters": {
          "$ref": "#/$defs/non_empty_string"
        },
        "hook_move": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_mode": {
          "$ref": "#/$defs/string_list"
        },
        "reusable_parts": {
          "$ref": "#/$defs/string_list"
        },
        "non_reusable_parts": {
          "$ref": "#/$defs/string_list"
        },
        "style_cue": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "capability_move": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "move_id",
        "label",
        "when_to_use"
      ],
      "properties": {
        "move_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "when_to_use": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "identity_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "author_handle",
        "author_display_name",
        "source_title",
        "published_at",
        "hosts",
        "guests",
        "other_participants"
      ],
      "properties": {
        "author_handle": {
          "type": [
            "string",
            "null"
          ]
        },
        "author_display_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_title": {
          "type": [
            "string",
            "null"
          ]
        },
        "published_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "hosts": {
          "$ref": "#/$defs/string_list"
        },
        "guests": {
          "$ref": "#/$defs/string_list"
        },
        "other_participants": {
          "$ref": "#/$defs/string_list"
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/non_empty_string"
    },
    "assembly_mode": {
      "type": "string",
      "const": "deterministic_selection"
    },
    "assembled_at": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "framework_match_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "framework_spec_ref": {
      "$ref": "#/$defs/non_empty_string"
    },
    "selected_framework": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "framework_id",
        "framework_label",
        "submode_id",
        "confidence"
      ],
      "properties": {
        "framework_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "framework_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "submode_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "confidence": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "assembly_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_summarization",
        "selected_spec_paths",
        "selected_sample_ids",
        "selection_rationale"
      ],
      "properties": {
        "no_summarization": {
          "type": "boolean",
          "const": true
        },
        "selected_spec_paths": {
          "$ref": "#/$defs/string_list",
          "description": "JSON pointer-like paths copied from FRAMEWORK_SPEC.json."
        },
        "selected_sample_ids": {
          "$ref": "#/$defs/string_list"
        },
        "selection_rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "structure_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hidden_skeleton",
        "visible_template_bans",
        "allowed_surface_moves",
        "forbidden_surface_moves",
        "selected_submode_spec"
      ],
      "properties": {
        "hidden_skeleton": {
          "$ref": "#/$defs/string_list"
        },
        "visible_template_bans": {
          "$ref": "#/$defs/string_list"
        },
        "allowed_surface_moves": {
          "$ref": "#/$defs/string_list"
        },
        "forbidden_surface_moves": {
          "$ref": "#/$defs/string_list"
        },
        "selected_submode_spec": {
          "$ref": "#/$defs/submode_spec"
        }
      }
    },
    "style_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "global_style_principles",
        "global_anti_ai_rules",
        "selected_style_profile"
      ],
      "properties": {
        "global_style_principles": {
          "$ref": "#/$defs/string_list"
        },
        "global_anti_ai_rules": {
          "$ref": "#/$defs/string_list"
        },
        "selected_style_profile": {
          "$ref": "#/$defs/style_profile"
        }
      }
    },
    "sample_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_sample_refs",
        "sample_selection_rationale"
      ],
      "properties": {
        "selected_sample_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sample_ref"
          }
        },
        "sample_selection_rationale": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "execution_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must_keep",
        "must_avoid",
        "rewrite_failure_modes",
        "quality_checks",
        "human_review_triggers"
      ],
      "properties": {
        "must_keep": {
          "$ref": "#/$defs/string_list"
        },
        "must_avoid": {
          "$ref": "#/$defs/string_list"
        },
        "rewrite_failure_modes": {
          "$ref": "#/$defs/string_list"
        },
        "quality_checks": {
          "$ref": "#/$defs/string_list"
        },
        "human_review_triggers": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "writer_guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "use_raw_source_as_primary_fact_base",
        "do_not_summarize_framework_spec",
        "preserve_hidden_structure_as_invisible",
        "prefer_sample_voice_over_template_surface"
      ],
      "properties": {
        "use_raw_source_as_primary_fact_base": {
          "type": "boolean",
          "const": true
        },
        "do_not_summarize_framework_spec": {
          "type": "boolean",
          "const": true
        },
        "preserve_hidden_structure_as_invisible": {
          "type": "boolean",
          "const": true
        },
        "prefer_sample_voice_over_template_surface": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "capability_packets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "playbook_version",
        "playbook_ref",
        "global_anti_patterns",
        "sample_quality_gate",
        "title_attack_packet",
        "dek_value_packet",
        "opening_value_packet",
        "mid_reset_plan",
        "closing_carry_packet"
      ],
      "properties": {
        "playbook_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "playbook_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "global_anti_patterns": {
          "$ref": "#/$defs/string_list"
        },
        "sample_quality_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "positive_sample_requirements",
            "minimum_positive_requirement_count",
            "exclude_patterns"
          ],
          "properties": {
            "positive_sample_requirements": {
              "$ref": "#/$defs/string_list"
            },
            "minimum_positive_requirement_count": {
              "type": "integer"
            },
            "exclude_patterns": {
              "$ref": "#/$defs/string_list"
            }
          }
        },
        "title_attack_packet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "job",
            "recommended_moves",
            "sample_hook_moves",
            "submode_hook_patterns",
            "stakes_signals",
            "forbidden_moves"
          ],
          "properties": {
            "job": {
              "$ref": "#/$defs/non_empty_string"
            },
            "recommended_moves": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/capability_move"
              }
            },
            "sample_hook_moves": {
              "$ref": "#/$defs/string_list"
            },
            "submode_hook_patterns": {
              "$ref": "#/$defs/string_list"
            },
            "stakes_signals": {
              "$ref": "#/$defs/string_list"
            },
            "forbidden_moves": {
              "$ref": "#/$defs/string_list"
            }
          }
        },
        "dek_value_packet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "job",
            "stable_moves",
            "sample_why_it_matters",
            "reader_payoff_signals",
            "forbidden_moves"
          ],
          "properties": {
            "job": {
              "$ref": "#/$defs/non_empty_string"
            },
            "stable_moves": {
              "$ref": "#/$defs/string_list"
            },
            "sample_why_it_matters": {
              "$ref": "#/$defs/string_list"
            },
            "reader_payoff_signals": {
              "$ref": "#/$defs/string_list"
            },
            "forbidden_moves": {
              "$ref": "#/$defs/string_list"
            }
          }
        },
        "opening_value_packet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "job",
            "stable_sequence",
            "identity_anchor",
            "sample_hook_moves",
            "opening_moves",
            "why_now_signals",
            "forbidden_moves"
          ],
          "properties": {
            "job": {
              "$ref": "#/$defs/non_empty_string"
            },
            "stable_sequence": {
              "$ref": "#/$defs/string_list"
            },
            "identity_anchor": {
              "$ref": "#/$defs/identity_anchor"
            },
            "sample_hook_moves": {
              "$ref": "#/$defs/string_list"
            },
            "opening_moves": {
              "$ref": "#/$defs/string_list"
            },
            "why_now_signals": {
              "$ref": "#/$defs/string_list"
            },
            "forbidden_moves": {
              "$ref": "#/$defs/string_list"
            }
          }
        },
        "mid_reset_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "job",
            "reset_frequency",
            "allowed_reset_moves",
            "format_helpers",
            "section_turn_targets",
            "forbidden_moves"
          ],
          "properties": {
            "job": {
              "$ref": "#/$defs/non_empty_string"
            },
            "reset_frequency": {
              "$ref": "#/$defs/non_empty_string"
            },
            "allowed_reset_moves": {
              "$ref": "#/$defs/string_list"
            },
            "format_helpers": {
              "$ref": "#/$defs/string_list"
            },
            "section_turn_targets": {
              "$ref": "#/$defs/string_list"
            },
            "forbidden_moves": {
              "$ref": "#/$defs/string_list"
            }
          }
        },
        "closing_carry_packet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "job",
            "recommended_moves",
            "closing_targets",
            "forbidden_endings"
          ],
          "properties": {
            "job": {
              "$ref": "#/$defs/non_empty_string"
            },
            "recommended_moves": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/capability_move"
              }
            },
            "closing_targets": {
              "$ref": "#/$defs/string_list"
            },
            "forbidden_endings": {
              "$ref": "#/$defs/string_list"
            }
          }
        }
      }
    }
  }
}
