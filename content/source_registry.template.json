{
  "version": "0.1.0",
  "description": "Template registry for source acquisition only. No framework routing fields here.",
  "source_groups": [
    {
      "group_id": "benchmark_x_threads",
      "enabled": true,
      "source_family": "benchmark_x_account",
      "source_type": "x_thread",
      "priority": "P0",
      "discovery_channel": "account_timeline",
      "fetch_mode": "fulltext",
      "fetcher": "x-tweet-fetcher",
      "window_hours": 24,
      "notes": "Use for high-density original posts and threads from benchmark accounts.",
      "items": [
        {
          "handle": "@example_benchmark",
          "label": "Example Benchmark Account"
        }
      ]
    },
    {
      "group_id": "benchmark_x_articles",
      "enabled": true,
      "source_family": "benchmark_x_account",
      "source_type": "x_article",
      "priority": "P0",
      "discovery_channel": "account_timeline_or_rss",
      "fetch_mode": "discover_then_fulltext",
      "fetcher": "x_article_fetcher",
      "window_hours": 24,
      "notes": "Discover article candidates from benchmark accounts, then fetch article body.",
      "items": [
        {
          "handle": "@example_benchmark",
          "label": "Example Benchmark Account"
        }
      ]
    },
    {
      "group_id": "podcast_transcripts",
      "enabled": true,
      "source_family": "podcast_show",
      "source_type": "podcast_transcript",
      "priority": "P0",
      "discovery_channel": "rss",
      "fetch_mode": "discover_then_fulltext",
      "fetcher": "rss_plus_transcript_enricher",
      "window_hours": 48,
      "notes": "Episode metadata is only a trigger source until transcript is attached.",
      "items": [
        {
          "show_id": "example_ai_podcast",
          "label": "Example AI Podcast",
          "rss_url": "https://example.com/feed.xml",
          "transcript_mode": "manual_or_subtitle"
        }
      ]
    },
    {
      "group_id": "official_web_sources",
      "enabled": true,
      "source_family": "official_web",
      "source_type": "blog_or_changelog",
      "priority": "P0",
      "discovery_channel": "rss_or_page_polling",
      "fetch_mode": "discover_then_fulltext",
      "fetcher": "rss_or_html_fetcher",
      "window_hours": 24,
      "notes": "Use for official blog posts, changelogs, and newsletters.",
      "items": [
        {
          "site_id": "example_vendor_blog",
          "label": "Example Vendor Blog",
          "homepage_url": "https://example.com/blog",
          "feed_url": "https://example.com/feed.xml"
        }
      ]
    },
    {
      "group_id": "fast_signal_sources",
      "enabled": false,
      "source_family": "signal_board",
      "source_type": "trigger_only",
      "priority": "P1",
      "discovery_channel": "rss_or_html",
      "fetch_mode": "discover_only",
      "fetcher": "rss_or_html_fetcher",
      "window_hours": 24,
      "notes": "Use for Product Hunt, Hacker News, Reddit, and similar sources. These should not go directly into article rewriting.",
      "items": [
        {
          "label": "Example Trigger Source",
          "homepage_url": "https://example.com"
        }
      ]
    }
  ]
}
