{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Publish Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "account_id",
    "platform",
    "publisher_type",
    "publish_mode",
    "publisher_account",
    "status",
    "scheduled_time",
    "timezone",
    "slot_dir",
    "content_ref"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "enum": [
        "x"
      ]
    },
    "publisher_type": {
      "type": "string",
      "enum": [
        "x_post_bitbrowser"
      ]
    },
    "publish_mode": {
      "type": "string",
      "enum": [
        "post",
        "article"
      ]
    },
    "publisher_account": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "publishing",
        "published",
        "failed",
        "cancelled"
      ]
    },
    "scheduled_time": {
      "type": "string",
      "minLength": 0,
      "description": "Local scheduled publish time, for example 2026-03-19 20:30. Empty is allowed for immediate article publishing."
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "slot_dir": {
      "type": "string",
      "minLength": 1
    },
    "content_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "run_id",
        "source_id",
        "article_json",
        "article_md"
      ],
      "properties": {
        "family": {
          "type": "string",
          "enum": [
            "podcast",
            "official_x",
            "article_x"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "article_json": {
          "type": "string",
          "minLength": 1
        },
        "article_md": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "post_txt": {
          "type": "string"
        },
        "post_jpg": {
          "type": "string"
        },
        "title_txt": {
          "type": "string"
        },
        "article_md": {
          "type": "string"
        },
        "article_publish_spec_json": {
          "type": "string"
        },
        "cover_jpg": {
          "type": "string"
        },
        "cover_image": {
          "type": "string"
        },
        "inline_images": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "publish_result_ref": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
